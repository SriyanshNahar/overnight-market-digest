# ===== Claude API (for summarization) =====
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ===== Telegram Bot =====
# Get TOKEN from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get CHAT_ID by messaging @userinfobot or your own bot + checking getUpdates
TELEGRAM_CHAT_ID=123456789

# ===== SendGrid (Email) =====
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=verified-sender@yourdomain.com
SENDGRID_TO_EMAIL=your-gmail@gmail.com

# ===== Optional: NewsAPI.org (extra news source, free tier) =====
NEWSAPI_KEY=

# ===== Settings =====
# How many hours back to look for news (9PM-9AM = 12hrs, +1 buffer = 13)
LOOKBACK_HOURS=13
# Max news items to send in digest
MAX_ITEMS=10
